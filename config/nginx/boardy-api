server {
    server_name api.bulochka.ai-info.ru;
 
    root /var/www/boardy-api;
    index index.html;
 
    access_log /var/log/nginx/boardy-api-access.log;
    error_log  /var/log/nginx/boardy-api-error.log;
 
    location / {
        try_files $uri $uri/ =404;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/api.bulochka.ai-info.ru/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/api.bulochka.ai-info.ru/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}
server {
    if ($host = api.bulochka.ai-info.ru) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name api.bulochka.ai-info.ru;
    return 404; # managed by Certbot


}